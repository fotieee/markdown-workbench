{
  "name": "markdown-workbench",
  "version": "1.0.0",
  "description": "A local Markdown workbench built with Electron and React.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:127.0.0.1:5173 && electron . --dev\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win",
    "pack": "npm run build && electron-builder --dir",
    "start": "electron .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "keywords": [
    "electron",
    "react",
    "markdown",
    "markdown-viewer",
    "desktop",
    "workbench"
  ],
  "author": "Markdown Workbench contributors",
  "license": "MIT",
  "engines": {
    "node": ">=14.21.0"
  },
  "dependencies": {
    "dompurify": "3.0.8",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.468.0",
    "marked": "4.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "concurrently": "8.2.2",
    "electron": "22.3.27",
    "electron-builder": "^24.13.3",
    "vite": "4.5.3",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.markdownworkbench.app",
    "productName": "Markdown Workbench",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
